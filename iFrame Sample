<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>iFrame Embed Example</title>
    <!-- Importing Tailwind CSS for modern styling -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col font-sans text-gray-800">
    
    <!-- Page Header -->
    <header class="bg-indigo-600 text-white py-6 px-4 shadow-md">
        <div class="max-w-6xl mx-auto">
            <h1 class="text-3xl font-semibold tracking-tight">Embedded Content Viewer</h1>
            <p class="text-indigo-200 mt-2">Demonstrating how to embed external websites using an HTML iframe.</p>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow p-4 md:p-8 flex flex-col items-center justify-start w-full">
        
        <!-- iFrame Container Wrapper -->
        <div class="w-full max-w-6xl bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden flex flex-col h-[75vh]">
            
            <!-- Mock Browser Top Bar (Aesthetics) -->
            <div class="bg-gray-100 px-4 py-3 flex items-center border-b border-gray-200 gap-4">
                <!-- Mac-style window controls -->
                <div class="flex gap-2">
                    <div class="w-3 h-3 rounded-full bg-red-400 border border-red-500"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-400 border border-yellow-500"></div>
                    <div class="w-3 h-3 rounded-full bg-green-400 border border-green-500"></div>
                </div>
                <!-- URL Bar -->
                <div class="flex-grow flex justify-center">
                    <div class="bg-white text-xs sm:text-sm text-gray-500 px-4 py-1.5 rounded-md w-full max-w-lg text-center truncate border border-gray-300 shadow-inner flex items-center justify-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                        https://dlptest.com/sample-data/
                    </div>
                </div>
                <!-- Empty div for flexbox balancing -->
                <div class="w-[52px]"></div>
            </div>

            <!-- The Actual iFrame -->
            <iframe 
                src="https://dlptest.com/sample-data/" 
                class="w-full flex-grow border-none bg-white"
                title="Embedded external content from dlptest.com"
                sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
            >
                <p>Your browser does not support iframes. Please update your browser to view this content.</p>
            </iframe>
        </div>

        <!-- Helpful Disclaimer/Note -->
        <div class="mt-8 max-w-6xl w-full text-sm text-amber-800 bg-amber-50 p-5 border border-amber-200 rounded-lg flex items-start gap-3 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
                <strong class="font-semibold block mb-1">Important Note regarding iFrames:</strong>
                If the content inside the frame above appears blank or refuses to connect, the target website (dlptest.com) may have updated its security headers (such as <code>X-Frame-Options</code> or <code>Content-Security-Policy: frame-ancestors</code>) to block embedding on external sites. However, test sites like DLP Test generally permit embedding for demonstration purposes.
            </div>
        </div>

    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-400 text-center py-4 text-sm mt-auto border-t border-gray-700">
        <p>&copy; 2026 iFrame Embed Demo. All rights reserved.</p>
    </footer>

</body>
</html>
